{
  "name": "arvya-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm --filter @arvya/web dev",
    "build": "pnpm --filter @arvya/web build",
    "start": "pnpm --filter @arvya/web start",
    "lint": "pnpm --filter @arvya/web lint",
    "typecheck": "pnpm --filter @arvya/web typecheck",
    "verify:foundation": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-foundation.ts",
    "verify:deal-brain": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-deal-brain.ts",
    "verify:live-deal-brain": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-live-deal-brain.ts",
    "verify:live-company-brain": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-live-company-brain.ts",
    "seed:deal-brain": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/seed-deal-brain.ts",
    "verify:seeded-deal-brain": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-seeded-deal-brain.ts",
    "verify:batch-ingestion": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-batch-ingestion.ts",
    "verify:ingestion-extraction": "tsx apps/web/scripts/verify-ingestion-extraction.ts",
    "verify:agent-evals": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-agent-evals.ts",
    "verify:closed-loop": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-closed-loop.ts",
    "verify:memory-quality": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-memory-quality.ts",
    "verify:scheduler-mock": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-scheduler-mock.ts",
    "verify:always-on": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-always-on.ts",
    "verify:open-loop-review": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-open-loop-review.ts",
    "verify:dashboard": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-dashboard.ts",
    "verify:company-drift": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-company-drift.ts",
    "verify:daily-brief": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-daily-brief.ts",
    "verify:drift-review": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-drift-review.ts",
    "verify:source-normalization": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-source-normalization.ts",
    "verify:ingestion-audit": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-ingestion-audit.ts",
    "verify:google-drive-mock": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-google-drive-mock.ts",
    "verify:email-connectors-mock": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-email-connectors-mock.ts",
    "verify:notetaker-mock": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-notetaker-mock.ts",
    "verify:notetaker-calendar-mock": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-notetaker-mock.ts",
    "verify:supabase": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-supabase.ts",
    "verify:deployment": "tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/verify-deployment.ts",
    "verify:live-end-to-end": "tsx --tsconfig apps/web/tsconfig.scripts.json apps/web/scripts/verify-live-end-to-end.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-direct": "tsx --tsconfig apps/web/tsconfig.scripts.json apps/web/scripts/migrate-direct.ts",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
