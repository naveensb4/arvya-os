# Supabase Postgres (use the pooled connection string from Supabase)
DATABASE_URL="postgresql://postgres:[password]@[project-ref].pooler.supabase.com:6543/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Models
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
DEFAULT_MODEL_PROVIDER="anthropic"
DEFAULT_MODEL="claude-sonnet-4-5"

# Inngest background runtime
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Recall.ai (Notetaker)
# Replit deployment URL is the canonical public base.
# After deploying, set ARVYA_PUBLIC_BASE_URL = https://arvya-os.<your-replit-domain>
ARVYA_PUBLIC_BASE_URL="http://localhost:3000"
RECALL_API_KEY=""
RECALL_BASE_URL="https://us-west-2.recall.ai/api/v1"
RECALL_WEBHOOK_SECRET=""

# Google Workspace OAuth (Drive transcript archive + Gmail + Calendar autojoin).
# When ARVYA_PUBLIC_BASE_URL is set, callbacks default to:
#   ${ARVYA_PUBLIC_BASE_URL}/api/connectors/google-drive/auth/callback
#   ${ARVYA_PUBLIC_BASE_URL}/api/connectors/gmail/auth/callback
#   ${ARVYA_PUBLIC_BASE_URL}/api/notetaker/google-calendar/auth/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/connectors/google-drive/auth/callback"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/notetaker/google-calendar/auth/callback"
GOOGLE_TRANSCRIPTS_FOLDER_ID=""
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3000/api/connectors/gmail/auth/callback"

# Microsoft 365 OAuth (Outlook mail + Calendar autojoin).
# Default callbacks when ARVYA_PUBLIC_BASE_URL is set:
#   ${ARVYA_PUBLIC_BASE_URL}/api/connectors/outlook/auth/callback
#   ${ARVYA_PUBLIC_BASE_URL}/api/notetaker/outlook-calendar/auth/callback
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/connectors/outlook/auth/callback"
MICROSOFT_CALENDAR_REDIRECT_URI="http://localhost:3000/api/notetaker/outlook-calendar/auth/callback"

# Optional: file storage bucket name in Supabase Storage. Defaults to "arvya-source-files".
SUPABASE_SOURCE_BUCKET=""
